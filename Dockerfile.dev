# syntax=docker/dockerfile:1
FROM amazonlinux:2023

# Install Python 3.12 and utilities.
# --allowerasing safely replaces the conflicting curl-minimal package with full curl
RUN dnf makecache && \
    dnf install -y --setopt=install_weak_deps=False --allowerasing \
    python3.12 python3.12-pip \
    git curl bash-completion \
    && dnf clean all && rm -rf /var/cache/dnf

WORKDIR /workspace

# Create non-root user to match production environment
RUN useradd -m -u 1000 slam -s /bin/bash

# Copy requirements
COPY requirements.txt .
COPY requirements-dev.txt .

# Install Python dependencies
RUN python3.12 -m pip install --no-cache-dir --upgrade pip setuptools wheel && \
    python3.12 -m pip install --no-cache-dir -r requirements.txt && \
    python3.12 -m pip install --no-cache-dir -r requirements-dev.txt

USER slam

# Ensure local bin is in PATH
ENV PATH="/home/slam/.local/bin:$PATH"